    "/api/users/signup": {
      "post": {
        "summary": "Create a new user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "password": {
                    "type": "string"
                  },
                  "confirmPassword": {
                    "type": "string"
                  }
                },
                "required": ["name", "email", "password", "confirmPassword"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User signed up"
          },
          "409": {
            "description": "Email already in use"
          },
          "422": {
            "description": "Validation failed"
          }
        }
      }
    },
    "/api/users/login": {
      "post": {
        "summary": "Login user",
        "requestBody": {
          "required": true,
