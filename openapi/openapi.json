                "type": "object",
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "password": {
                    "type": "string"
                  }
                },
                "required": ["email", "password"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Logged in"
          },
          "401": {
            "description": "Invalid credentials"
          },
          "422": {
            "description": "Validation failed"
          }
        }
      }
    },
