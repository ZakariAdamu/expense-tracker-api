{
  "name": "expense-tracker-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon --exec tsx src/server.ts",
    "kill-port": "kill-port 4000",
    "build": "tsc",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write .",
    "type-check": "tsc --noEmit",
    "prestart": "npm run build",
    "prepush": "npm run type-check && npm run build",
    "start": "node dist/server.js",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "dependencies": {
    "@types/express": "^4.17.21",
    "cors": "^2.8.5",
    "cookie-parser": "^1.4.7",
    "compression": "^1.8.1",
    "bcrypt": "^6.0.0",
    "jsonwebtoken": "^9.0.3",
    "@types/cors": "^2.8.19",
    "@types/cookie-parser": "^1.4.10",
    "@types/compression": "^1.8.1",
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "dotenv": "^17.4.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.1",
    "helmet": "^8.1.0",
    "mongoose": "^9.3.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.7.1",
    "@commitlint/config-conventional": "^19.7.1",
    "@commitlint/types": "^19.5.0",
    "@eslint/js": "^9.10.0",
    "@types/node": "^20.14.12",
    "eslint": "^9.10.0",
    "husky": "^9.1.7",
    "kill-port": "^2.0.1",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.3.3",
    "pretty-quick": "^4.2.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.59.2"
  }
}
