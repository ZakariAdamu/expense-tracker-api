{
	"name": "expense-tracker-api",
	"version": "0.1.0",
	"private": true,
	"type": "commonjs",
	"scripts": {
		"dev": "nodemon --exec ts-node src/server.ts",
		"build": "tsc",
		"lint": "eslint src --ext .ts",
		"type-check": "tsc --noEmit",
		"prestart": "npm run kill-port && npm run build",
		"start": "node dist/server.js"
	},
	"dependencies": {
		"bcrypt": "^6.0.0",
		"compression": "^1.8.1",
		"cookie-parser": "^1.4.7",
		"cors": "^2.8.5",
		"dotenv": "^17.4.0",
		"express": "^4.21.2",
		"express-rate-limit": "^8.5.1",
		"helmet": "^8.1.0",
		"jsonwebtoken": "^9.0.3",
		"mongoose": "^9.3.3",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@types/bcrypt": "^6.0.0",
		"@types/compression": "^1.8.1",
		"@types/cookie-parser": "^1.4.10",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.0",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/node": "^22.13.4",
		"nodemon": "^3.1.14",
		"ts-node-dev": "^2.0.0",
		"tsx": "^4.19.2",
		"typescript": "^5.8.2"
	}
}
